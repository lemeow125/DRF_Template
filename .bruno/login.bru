meta {
  name: Login & Get Users
  type: http
  seq: 1
}

post {
  url: {{BASE_URL}}/accounts/jwt/create/
  body: json
  auth: none
}

body:json {
  {
    "username": "{{ADMIN_EMAIL}}",
    "password": "{{USER_PASSWORD}}"
  }
}

tests {
  test("Should return success", () => {
    expect(res.status).to.equal(200);
  });

  if (res.status !== 200) {
    console.log("Trace:", res.body);
  }
}
